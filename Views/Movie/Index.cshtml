@model IEnumerable<Mission06_YourLastName.Models.Movie>

@{
    ViewData["Title"] = "Movie Collection";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="mb-0">Joel's Movie Collection</h1>
    <a asp-action="Create" class="btn btn-primary">Add New Movie</a>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered table-hover align-middle">
        <thead class="table-dark">
            <tr>
                <th>@Html.DisplayNameFor(model => model.Title)</th>
                <th>@Html.DisplayNameFor(model => model.Year)</th>
                <th>Category</th>
                <th>@Html.DisplayNameFor(model => model.Director)</th>
                <th>@Html.DisplayNameFor(model => model.Rating)</th>
                <th>@Html.DisplayNameFor(model => model.Edited)</th>
                <th>@Html.DisplayNameFor(model => model.CopiedToPlex)</th>
                <th>@Html.DisplayNameFor(model => model.LentTo)</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@Html.DisplayFor(modelItem => item.Title)</td>
                    <td>@Html.DisplayFor(modelItem => item.Year)</td>
                    <td>@(item.Category?.CategoryName)</td>
                    <td>@Html.DisplayFor(modelItem => item.Director)</td>
                    <td>@Html.DisplayFor(modelItem => item.Rating)</td>
                    <td>@(item.Edited ? "Yes" : "No")</td>
                    <td>@(item.CopiedToPlex ? "Yes" : "No")</td>
                    <td>@Html.DisplayFor(modelItem => item.LentTo)</td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.MovieId" class="btn btn-sm btn-outline-primary">Edit</a>
                        <a asp-action="Details" asp-route-id="@item.MovieId" class="btn btn-sm btn-outline-secondary">Details</a>
                        <a asp-action="Delete" asp-route-id="@item.MovieId" class="btn btn-sm btn-outline-danger">Delete</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

@if (!Model.Any())
{
    <p class="text-muted text-center py-4">No movies in the collection yet. <a asp-action="Create">Add your first movie</a>.</p>
}
